# MakitiPlus — Environment Variables
# Copy this file to .env and fill in your values
#
# ⚠️ SECURITY: .env files must NEVER be committed to Git.
# If a key was ever exposed, rotate it immediately in the Supabase dashboard.
# See: https://supabase.com/docs/guides/api/api-keys#securing-your-api-keys

# Supabase
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Sentry — leave empty to disable monitoring
VITE_SENTRY_DSN=""
VITE_SENTRY_ENVIRONMENT="production"
VITE_SENTRY_TRACES_SAMPLE_RATE="0.1"
VITE_SENTRY_REPLAY_SAMPLE_RATE="0.05"
